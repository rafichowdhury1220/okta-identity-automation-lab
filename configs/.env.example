# Environment Configuration
# Copy this file to .env and fill in your actual values

# Okta Configuration
OKTA_ORG_URL=https://your-org.okta.com
OKTA_API_TOKEN=your-api-token-here
OKTA_AUTH_METHOD=api_token

# Application Settings
DEBUG=False
LOG_LEVEL=INFO

# MFA Settings
MFA_ENABLED=True
MFA_REQUIRED_FACTORS=OKTA,SMS,DUO

# Zero Trust Settings
ZERO_TRUST_ENABLED=True
MINIMUM_TRUST_SCORE=0.5

# SCIM Settings
SCIM_ENABLED=True
SCIM_BATCH_SIZE=100

# Database (optional)
# DATABASE_URL=sqlite:///okta_lab.db
